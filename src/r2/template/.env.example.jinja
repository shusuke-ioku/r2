# r2 — API Keys Configuration
# Copy this file to .env and fill in your keys.
# Only ANTHROPIC_API_KEY is required. Everything else is optional.

# ──────────────────────────────────────────────
# REQUIRED — Powers Claude generation in RAG queries
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# OPTIONAL — External literature search APIs
# ──────────────────────────────────────────────

# OpenAlex (free, no key needed, but email gets you into the polite pool)
# Sign up: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
# RAG_OPENALEX_EMAIL=

# Scopus (requires institutional or developer API key)
# Sign up: https://dev.elsevier.com/
# RAG_SCOPUS_API_KEY=

# Semantic Scholar (works without key, but key raises rate limits)
# Sign up: https://www.semanticscholar.org/product/api#api-key
# RAG_S2_API_KEY=

# ──────────────────────────────────────────────
# OPTIONAL — Paper downloads via Sci-Hub
# ──────────────────────────────────────────────
# RAG_SCIHUB_URL=https://sci-hub.st
{% if use_zotero %}
# ──────────────────────────────────────────────
# OPTIONAL — Zotero integration
# ──────────────────────────────────────────────
# Get your key at: https://www.zotero.org/settings/keys
# Your user ID is at: https://www.zotero.org/settings/keys (numeric ID in URL)
# RAG_ZOTERO_API_KEY=
# RAG_ZOTERO_USER_ID=
{% endif %}

# Skills engine uses ANTHROPIC_API_KEY (already set above) for Cognee's cognify step.
# No additional key needed.
